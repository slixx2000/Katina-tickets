# Optional AI tooling key (not required for ticket purchase/auth runtime)
GEMINI_API_KEY=""

# Application URLs
# APP_URL is used for callback URL generation (for example payment provider callback URL).
APP_URL="http://localhost:3000"
APP_ORIGIN="http://localhost:3000"
CSRF_ALLOWED_ORIGINS="http://localhost:3000,https://your-domain.com"
REQUIRE_DATABASE="false"

# Supabase backend + auth (required for proper production auth)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_TICKETS_BUCKET="tickets"
TICKET_DELIVERY_PROVIDER=""

# Session/auth security
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET"
ADMIN_CONSOLE_ALLOWLIST_EMAILS="katina@example.com,shaun@example.com"
SESSION_TTL_SECONDS="28800"
REFRESH_TTL_SECONDS="2592000"
SESSION_COOKIE_NAME="katina-session"
REFRESH_COOKIE_NAME="katina-refresh"
RATE_LIMIT_AUTH_PER_MINUTE="8"
RATE_LIMIT_PAYMENT_PER_MINUTE="20"
PDF_UPLOAD_RETRY_TOKEN="REPLACE_WITH_RANDOM_INTERNAL_TOKEN"

# Local-only fallback for mock tokens. Keep false unless intentionally testing without Supabase.
ALLOW_DEV_AUTH_BYPASS="false"

# MFA
MFA_TOTP_ISSUER="Katina Tickets"
MFA_SECRET_ENCRYPTION_KEY="REPLACE_WITH_A_LONG_RANDOM_SECRET"

# Bila payment gateway
# Keep BILA secret values server-side only. Never expose BILA_SECRET_KEY or BILA_WEBHOOK_SECRET to the browser.
# VITE_BILA_PUBLIC_KEY is safe for the browser widget.
BILA_ENV="production"
VITE_BILA_PUBLIC_KEY="pk_live_TT6V_-kphfAPQIO-kIDKJ_6DkoKwJErR"
BILA_PUBLIC_KEY="pk_live_TT6V_-kphfAPQIO-kIDKJ_6DkoKwJErR"
BILA_SECRET_KEY="sk_live_Yl2evgA1lXy4-AIUVgPg_-uCh3JnkppHY"
BILA_API_BASE_URL="https://api.usebila.com"
BILA_WEBHOOK_URL="https://your-domain.com/api/webhooks/bila"
BILA_WEBHOOK_SECRET="bc5dd7a4d3d3c16da8cf0def2132661af93adca87ed92f65d215a3b3c7201832"
BILA_SUCCESS_URL="https://katinabasil.com/payment/success"
BILA_CANCEL_URL="https://katinabasil.com/payment/cancel"

# Clerk
# By default, the app uses the live/published Clerk instance for all environments.
# If you want localhost to use a separate Clerk dev instance, set both toggles to true
# and provide matching DEV keys on frontend + backend.
VITE_CLERK_PUBLISHABLE_KEY="YOUR_CLERK_PUBLISHABLE_KEY"
VITE_CLERK_PUBLISHABLE_KEY_DEV=""
VITE_CLERK_USE_DEV_INSTANCE="false"
CLERK_SECRET_KEY="YOUR_CLERK_SECRET_KEY"
CLERK_SECRET_KEY_DEV=""
CLERK_USE_DEV_INSTANCE="false"
