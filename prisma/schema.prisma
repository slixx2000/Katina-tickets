generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SUPER_ADMIN
  ORGANIZER
  SCANNER
  SUPPORT
  FINANCE
}

enum AuthProvider {
  SUPABASE
  GOOGLE
  CREDENTIALS
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum MfaFactorType {
  TOTP
  WEBAUTHN
  BACKUP_CODE
}

enum MfaFactorStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  MFA_ENROLLED
  MFA_VERIFIED
  MFA_FAILED
  SESSION_CREATED
  SESSION_ROTATED
  SESSION_REVOKED
  ROLE_CHANGED
  PERMISSION_DENIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum TicketInventoryType {
  ORDINARY
  VIP
}

enum TicketStatus {
  ACTIVE
  CHECKED_IN
  REFUNDED
  CANCELLED
}

enum TicketScanResult {
  VALID
  ALREADY_CHECKED_IN
  REFUNDED
  CANCELLED
  INVALID_TICKET
}

enum PdfUploadRetryStatus {
  PENDING
  SUCCEEDED
  EXHAUSTED
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  image          String?
  role           UserRole      @default(SUPPORT)
  provider       AuthProvider  @default(SUPABASE)
  providerUserId String?       @unique
  passwordHash   String?
  mfaEnabled     Boolean       @default(false)
  isActive       Boolean       @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sessions       Session[]
  refreshTokens  RefreshToken[]
  payments       PaymentTransaction[]
  reservations   PaymentReservation[]
  checkedInTickets Ticket[]       @relation("TicketCheckedInBy")
  ticketScanLogs  TicketScanLog[] @relation("ScannerAdmin")
  mfaFactors     MfaFactor[]
  auditLogs      AuditLog[]    @relation("ActorAuditLogs")
  roleChanges    AuditLog[]    @relation("TargetUserRoleChanges")

  @@index([role])
  @@index([provider, providerUserId])
}

model Session {
  id               String        @id @default(cuid())
  userId           String
  sessionTokenHash String        @unique
  refreshTokenHash String        @unique
  status           SessionStatus @default(ACTIVE)
  expiresAt        DateTime
  refreshExpiresAt DateTime
  lastSeenAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, status])
  @@index([expiresAt])
}

model RefreshToken {
  id               String   @id @default(cuid())
  userId           String
  sessionId        String?
  tokenHash        String   @unique
  rotatedFromToken String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
}

model MfaFactor {
  id          String          @id @default(cuid())
  userId      String
  type        MfaFactorType
  status      MfaFactorStatus @default(PENDING)
  label       String?
  secret      String?         @db.Text
  publicKey   String?         @db.Text
  counter     Int             @default(0)
  verifiedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AuditLog {
  id           String      @id @default(cuid())
  action       AuditAction
  actorUserId  String?
  targetUserId String?
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  actor  User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)
  target User? @relation("TargetUserRoleChanges", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action, createdAt])
}

model PaymentTransaction {
  id                String        @id @default(cuid())
  reference         String        @unique
  providerPaymentId String?
  userId            String?
  amount            Int
  currency          String
  description       String
  customerEmail     String?
  customerName      String?
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  paidAt            DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  provider        String
  providerEventId String   @unique
  signature       String?
  payload         Json
  processedAt     DateTime @default(now())

  @@index([provider, processedAt])
}

model TicketInventory {
  id        String             @id @default(cuid())
  type      TicketInventoryType @unique
  price     Int
  remaining Int
  totalCap  Int
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([type])
}

model PaymentReservation {
  id               String            @id @default(cuid())
  paymentReference String            @unique
  userId           String?
  fullName         String
  email            String
  ticketType       TicketInventoryType
  quantity         Int
  seatDetails      Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tickets Ticket[]

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketType])
  @@index([createdAt])
}

model Event {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  startsAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]

  @@index([createdAt])
}

model Ticket {
  id                String             @id @default(uuid())
  ticketId          String             @unique
  qrCodeValue       String             @unique
  reservationId     String
  eventId           String
  ticketType        TicketInventoryType
  holderName        String
  holderEmail       String
  status            TicketStatus       @default(ACTIVE)
  pdfStoragePath    String?
  pdfChecksum       String?
  pdfGeneratedAt    DateTime?
  checkedInAt       DateTime?
  checkedInByAdminId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  reservation       PaymentReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  event             Event              @relation(fields: [eventId], references: [id], onDelete: Restrict)
  checkedInByAdmin  User?              @relation("TicketCheckedInBy", fields: [checkedInByAdminId], references: [id], onDelete: SetNull)
  scanLogs          TicketScanLog[]
  failedPdfUploads  FailedPdfUpload[]

  @@index([reservationId])
  @@index([eventId])
  @@index([status])
  @@index([pdfStoragePath])
  @@index([holderEmail])
  @@index([holderName])
}

model TicketScanLog {
  id             String           @id @default(uuid())
  ticketId       String?
  scannerAdminId String?
  scanTimestamp  DateTime         @default(now())
  result         TicketScanResult
  deviceInfo     Json?
  scannedValue   String

  ticket         Ticket?          @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  scannerAdmin   User?            @relation("ScannerAdmin", fields: [scannerAdminId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([scannerAdminId])
  @@index([scanTimestamp])
  @@index([result])
}

model TicketSequence {
  id         Int      @id
  lastIssued Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model FailedPdfUpload {
  id               String               @id @default(cuid())
  paymentReference String
  ticketRecordId   String               @unique
  ticketPublicId   String
  storagePath      String
  attemptCount     Int                  @default(0)
  lastError        String?
  status           PdfUploadRetryStatus @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  lastAttemptAt    DateTime?
  nextAttemptAt    DateTime             @default(now())

  ticket Ticket @relation(fields: [ticketRecordId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([paymentReference])
}
