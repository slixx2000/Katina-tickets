generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ORGANIZER
  SCANNER
  SUPPORT
  FINANCE
}

enum AuthProvider {
  SUPABASE
  GOOGLE
  CREDENTIALS
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum MfaFactorType {
  TOTP
  WEBAUTHN
  BACKUP_CODE
}

enum MfaFactorStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  MFA_ENROLLED
  MFA_VERIFIED
  MFA_FAILED
  SESSION_CREATED
  SESSION_ROTATED
  SESSION_REVOKED
  ROLE_CHANGED
  PERMISSION_DENIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum TicketInventoryType {
  ORDINARY
  VIP
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  image          String?
  role           UserRole      @default(SUPPORT)
  provider       AuthProvider  @default(SUPABASE)
  providerUserId String?       @unique
  passwordHash   String?
  mfaEnabled     Boolean       @default(false)
  isActive       Boolean       @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sessions       Session[]
  refreshTokens  RefreshToken[]
  payments       PaymentTransaction[]
  reservations   PaymentReservation[]
  mfaFactors     MfaFactor[]
  auditLogs      AuditLog[]    @relation("ActorAuditLogs")
  roleChanges    AuditLog[]    @relation("TargetUserRoleChanges")

  @@index([role])
  @@index([provider, providerUserId])
}

model Session {
  id               String        @id @default(cuid())
  userId           String
  sessionTokenHash String        @unique
  refreshTokenHash String        @unique
  status           SessionStatus @default(ACTIVE)
  expiresAt        DateTime
  refreshExpiresAt DateTime
  lastSeenAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, status])
  @@index([expiresAt])
}

model RefreshToken {
  id               String   @id @default(cuid())
  userId           String
  sessionId        String?
  tokenHash        String   @unique
  rotatedFromToken String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
}

model MfaFactor {
  id          String          @id @default(cuid())
  userId      String
  type        MfaFactorType
  status      MfaFactorStatus @default(PENDING)
  label       String?
  secret      String?         @db.Text
  publicKey   String?         @db.Text
  counter     Int             @default(0)
  verifiedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AuditLog {
  id           String      @id @default(cuid())
  action       AuditAction
  actorUserId  String?
  targetUserId String?
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  actor  User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)
  target User? @relation("TargetUserRoleChanges", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action, createdAt])
}

model PaymentTransaction {
  id                String        @id @default(cuid())
  reference         String        @unique
  providerPaymentId String?
  userId            String?
  amount            Int
  currency          String
  description       String
  customerEmail     String?
  customerName      String?
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  paidAt            DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  provider        String
  providerEventId String   @unique
  signature       String?
  payload         Json
  processedAt     DateTime @default(now())

  @@index([provider, processedAt])
}

model TicketInventory {
  id        String             @id @default(cuid())
  type      TicketInventoryType @unique
  price     Int
  remaining Int
  totalCap  Int
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([type])
}

model PaymentReservation {
  id               String            @id @default(cuid())
  paymentReference String            @unique
  userId           String?
  fullName         String
  email            String
  ticketType       TicketInventoryType
  quantity         Int
  seatDetails      Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketType])
  @@index([createdAt])
}
